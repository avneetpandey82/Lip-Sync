# ── Required ────────────────────────────────────────────────────────────────────
# OpenAI API key used for chat completions and TTS
OPENAI_API_KEY=sk-...

# ── Optional ────────────────────────────────────────────────────────────────────
# Set to "true" if the Rhubarb binary is available inside the container
RHUBARB_AVAILABLE=false

# Path to the Rhubarb binary (only needed when RHUBARB_AVAILABLE=true)
# RHUBARB_PATH=/usr/local/bin/rhubarb
